{
  "name": "@addfox/cli",
  "version": "0.1.1",
  "description": "addfox CLI: addfox dev / build, parses argv and drives Rsbuild",
  "license": "MIT",
  "type": "module",
  "bin": {
    "addfox": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@rspack/core": "catalog:",
    "@addfox/common": "workspace:*",
    "@addfox/core": "workspace:*",
    "@addfox/pkg-manager": "workspace:*",
    "archiver": "^7.0.0",
    "@addfox/rsbuild-plugin-extension-entry": "workspace:*",
    "@addfox/rsbuild-plugin-extension-manifest": "workspace:*",
    "@addfox/rsbuild-plugin-extension-hmr": "workspace:*",
    "@addfox/rsbuild-plugin-extension-monitor": "workspace:*",
    "@addfox/rsbuild-plugin-vue": "workspace:*"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/archiver": "^6.0.0",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rsbuild/core": "catalog:"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": false
    }
  }
}
