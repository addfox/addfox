{
  "name": "create-addfox-app",
  "version": "0.2.5",
  "description": "Interactive scaffolder for addfox extension projects",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "create-addfox-app": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "prepack": "rslib build",
    "start": "node dist/cli.js",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "dependencies": {
    "@addfox/pkg-manager": "workspace:*",
    "prompts": "^2.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "@types/prompts": "^2.4.9",
    "typescript": "catalog:"
  }
}
