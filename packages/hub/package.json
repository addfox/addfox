{
  "name": "@addfox/hub",
  "version": "0.1.0",
  "description": "Addfox Hub - Browser extension development manager and launcher",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hub": "./dist/cli.js"
  },
  "files": [
    "dist",
    "dist-ui",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "build:ui": "cd ui && pnpm build",
    "build:all": "pnpm build && pnpm build:ui",
    "dev": "rslib build --watch",
    "dev:ui": "cd ui && pnpm dev",
    "dev:backend": "node ./dist/cli.js start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@addfox/common": "workspace:*",
    "@addfox/core": "workspace:*",
    "@hono/node-server": "^1.19.12",
    "@rsbuild/core": "^1.7.3",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "get-port": "^7.1.0",
    "globby": "^14.0.0",
    "hono": "^4.12.9",
    "lowdb": "^7.0.1",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "ws": "^8.19.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
