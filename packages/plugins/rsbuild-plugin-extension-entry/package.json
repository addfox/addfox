{
  "name": "@addfox/rsbuild-plugin-extension-entry",
  "version": "0.1.1-beta.9",
  "description": "Rsbuild plugin: multi-entry, HTML and public copy (internal)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "main": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "dependencies": {
    "@addfox/core": "workspace:*"
  },
  "devDependencies": {
    "@rspack/core": "^1.7.8",
    "@rsbuild/core": "^1.7.3",
    "@rslib/core": "^0.20.0",
    "@rstest/core": "^0.9.2",
    "@rstest/coverage-istanbul": "^0.3.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@rsbuild/core": ">=1.0.0",
    "@rspack/core": ">=1.0.0"
  }
}
