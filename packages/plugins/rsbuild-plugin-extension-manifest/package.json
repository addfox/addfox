{
  "name": "@addfox/rsbuild-plugin-extension-manifest",
  "version": "0.1.1-beta.12",
  "description": "Rsbuild plugin: write manifest.json and remove stray HTML (internal)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "main": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "dependencies": {
    "@addfox/core": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rspack/core": "catalog:",
    "@rsbuild/core": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rsbuild/core": "catalog:",
    "@rspack/core": "catalog:"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": false
    },
    "@rspack/core": {
      "optional": false
    }
  }
}
