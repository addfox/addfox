{
  "name": "@addfox/rsbuild-plugin-vue",
  "version": "0.1.1-beta.10",
  "description": "addfox plugin: enable Vue 3 (SFC, JSX via @rsbuild/plugin-vue-jsx) for the project",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "main": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rspack/core": "catalog:",
    "@rsbuild/core": "catalog:",
    "@rsbuild/plugin-babel": "catalog:",
    "@rsbuild/plugin-vue": "catalog:",
    "@rsbuild/plugin-vue-jsx": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "@vue/compiler-sfc": "^3.2.47",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rsbuild/core": "catalog:",
    "@rspack/core": "catalog:",
    "@rsbuild/plugin-babel": "catalog:",
    "@rsbuild/plugin-vue": "catalog:",
    "@rsbuild/plugin-vue-jsx": "catalog:",
    "@vue/compiler-sfc": ">=3.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": false
    },
    "@rspack/core": {
      "optional": false
    },
    "@rsbuild/plugin-babel": {
      "optional": false
    },
    "@rsbuild/plugin-vue": {
      "optional": false
    },
    "@rsbuild/plugin-vue-jsx": {
      "optional": false
    },
    "vue": {
      "optional": true
    }
  }
}
