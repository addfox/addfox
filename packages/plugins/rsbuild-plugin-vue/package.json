{
  "name": "@addfox/rsbuild-plugin-vue",
  "version": "0.1.1-beta.9",
  "description": "addfox plugin: enable Vue 3 (SFC, JSX via @rsbuild/plugin-vue-jsx) for the project",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "main": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "devDependencies": {
    "@rspack/core": "^1.7.8",
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-babel": "^1.1.2",
    "@rsbuild/plugin-vue": "^1.2.7",
    "@rsbuild/plugin-vue-jsx": "^1.1.2",
    "@rslib/core": "^0.20.0",
    "@rstest/core": "^0.9.2",
    "@rstest/coverage-istanbul": "^0.3.0",
    "@types/node": "^20.0.0",
    "@vue/compiler-sfc": "^3.2.47",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@rsbuild/core": ">=1.0.0",
    "@rspack/core": ">=1.0.0",
    "@rsbuild/plugin-babel": ">=1.0.0",
    "@rsbuild/plugin-vue": ">=1.0.0",
    "@rsbuild/plugin-vue-jsx": ">=1.0.0",
    "@vue/compiler-sfc": ">=3.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  }
}
