{
  "name": "@addfox/core",
  "version": "0.1.1-beta.12",
  "description": "addfox core: types, config loading, entry discovery/resolution, manifest building",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    },
    "./pipeline": {
      "types": "./dist/esm/pipeline/index.d.ts",
      "import": "./dist/esm/pipeline/index.js",
      "require": "./dist/cjs/pipeline/index.cjs",
      "default": "./dist/esm/pipeline/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@addfox/common": "workspace:*",
    "cli-table3": "^0.6.5",
    "jiti": "^2.0.0"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rsbuild/core": "catalog:"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": false
    }
  }
}
