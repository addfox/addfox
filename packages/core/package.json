{
  "name": "@addfox/core",
  "version": "0.1.1-beta.8",
  "description": "addfox core: types, config loading, entry discovery/resolution, manifest building",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    },
    "./pipeline": {
      "types": "./dist/esm/pipeline/index.d.ts",
      "import": "./dist/esm/pipeline/index.js",
      "require": "./dist/cjs/pipeline/index.cjs",
      "default": "./dist/esm/pipeline/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run",
    "test:coverage": "rstest run --coverage"
  },
  "dependencies": {
    "@addfox/common": "workspace:*",
    "@rsbuild/core": "^1.7.3",
    "cli-table3": "^0.6.5",
    "jiti": "^2.0.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "@rstest/core": "^0.9.2",
    "@rstest/coverage-istanbul": "^0.3.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@rsbuild/core": ">=1.0.0"
  }
}
