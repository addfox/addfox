  },
  "dependencies": {
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.0.0",
    "@rslib/core": "^0.20.0",
    "@rstest/core": "^0.9.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0"
  }
}
