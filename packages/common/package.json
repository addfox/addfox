{
  "name": "@addfox/common",
  "version": "0.1.1",
  "description": "Shared utilities for Addfox packages",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/esm/index.d.ts"
    },
    "./browser": {
      "import": "./dist/esm/browser.js",
      "require": "./dist/cjs/browser.cjs",
      "types": "./dist/esm/browser/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "rstest run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
