{
  "name": "@addfox/common",
  "version": "0.1.1-beta.2",
  "description": "Shared utilities for Addfox packages",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
