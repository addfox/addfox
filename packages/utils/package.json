{
  "name": "@addfox/utils",
  "version": "0.1.1-beta.14",
  "description": "Extension utils: content UI (defineContentUI / mountContentUI) for content scripts",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
